# ============================================================
# Social Poster Platform — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Application ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development
APP_URL=http://localhost:5000
LOG_LEVEL=info

# ── Database (PostgreSQL) ────────────────────────────────────
# Replit auto-sets DATABASE_URL when you add a PostgreSQL database
DATABASE_URL=postgresql://user:password@host:5432/database
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password
PGDATABASE=social_poster

# ── Authentication ───────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=change-me-to-a-very-long-random-secret-string
JWT_EXPIRES_IN=7d
SESSION_SECRET=another-long-random-secret-for-sessions

# ── Telegram Bot ─────────────────────────────────────────────
# Get your token from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_from_botfather

# Comma-separated list of admin Telegram user IDs
# Get your ID from @userinfobot on Telegram
TELEGRAM_ADMIN_IDS=123456789,987654321

# ── OpenAI (AI content generation) ──────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ── Security ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5000
RATE_LIMIT_PER_MINUTE=60

# ── Social Media Platforms ───────────────────────────────────
# Sessions are stored locally via social-poster CLI
# Use: node bin/social-poster.js login <platform>
# Supported: x, linkedin, reddit, facebook, hacker-news, stacker-news, primal

# ── File Uploads ─────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=uploads

# ── Debug ────────────────────────────────────────────────────
DB_DEBUG=false
